# ============================================================
#  KoALa-back 로컬 개발 환경 변수 템플릿
#  이 파일을 복사해서 .env 로 만든 뒤 실제 값을 채워주세요.
#  .env 파일은 절대 git에 커밋하지 마세요.
# ============================================================

# ── 데이터베이스 ─────────────────────────────────────────────
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ── Redis ────────────────────────────────────────────────────
# 비밀번호 없는 로컬 Redis면 빈 값으로 두세요
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────
# 최소 32자 이상의 랜덤 문자열 (openssl rand -base64 64 로 생성 권장)
JWT_SECRET=your-very-long-random-secret-key-minimum-32-characters

# ── OAuth2 ───────────────────────────────────────────────────
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ── 메일 ─────────────────────────────────────────────────────
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ── AWS S3 ───────────────────────────────────────────────────
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key

# ── 토스페이먼츠 ──────────────────────────────────────────────
# 테스트 키: https://developers.tosspayments.com 에서 발급
TOSS_SECRET_KEY=test_sk_your_toss_secret_key
