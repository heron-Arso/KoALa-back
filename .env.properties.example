# ============================================================
#  이 파일을 복사해서 프로젝트 루트에 .env.properties 로 만드세요.
#  Spring Boot가 로컬 실행 시 자동으로 읽습니다.
#  .env.properties 는 절대 git에 커밋하지 마세요.
#
#  생성 방법:
#    cp .env.properties.example .env.properties
#    # 이후 실제 값으로 수정
# ============================================================

# ── 데이터베이스 ─────────────────────────────────────────────
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────
# openssl rand -base64 64 로 생성 권장
JWT_SECRET=your-very-long-random-secret-key-minimum-32-characters

# ── OAuth2 ───────────────────────────────────────────────────
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ── 메일 ─────────────────────────────────────────────────────
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ── AWS S3 ───────────────────────────────────────────────────
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key

# ── 토스페이먼츠 ──────────────────────────────────────────────
TOSS_SECRET_KEY=test_sk_your_toss_secret_key
